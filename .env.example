# Copiá este archivo como .env y completá los valores
# NUNCA subas .env a GitHub

# Binance
BINANCE_API_KEY=tu_key_aqui
BINANCE_API_SECRET=tu_secret_aqui
BINANCE_TESTNET=true

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Telegram
TELEGRAM_TOKEN=123456:ABC...
TELEGRAM_CHAT_ID=123456789

# GitHub Gist (para el dashboard remoto)
# Crear en: https://github.com/settings/tokens → New token → solo scope "gist"
GITHUB_GIST_TOKEN=ghp_...
GITHUB_GIST_ID=abc123...   # se genera al crear el primer gist
